---
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import YouTubeTestimonial from '../components/YouTubeTestimonial.astro';

interface Props {
  title: string;
  description?: string;
  hideYouTube?: boolean;
}

const { title, description = 'Real World PDR - The Best Online PDR Training Available', hideYouTube = false } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/png" sizes="32x32" href="https://devtools.prairiegiraffe.com/api/files/sites/proj_dkm43vn7/1776723863099/assets/mo7rj6unjueh8i.png" />
    <link rel="apple-touch-icon" href="https://devtools.prairiegiraffe.com/api/files/sites/proj_dkm43vn7/1776723863099/assets/mo7rj6wbxtc5wz.png" />
    <script is:inline src="https://devtools.prairiegiraffe.com/api/projects/proj_dkm43vn7/forms/embed.js" defer></script>
  </head>
  <body class="font-body text-gray-body bg-white">
    <SiteHeader />
    <slot />
    {!hideYouTube && <YouTubeTestimonial />}
    <SiteFooter />
  </body>
</html>
