---
export interface Props {
  id?: string;
}

const { id = "cta" } = Astro.props;
---

<section id={id} class="py-16 bg-gradient-to-b from-gray-50 to-white">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <div class="mb-8">
      <img 
        src="/api/files/sites/proj_dkm43vn7/1776723863099/assets/mo7ye9h42cusx6.jpg" 
        alt="red car dent free"
        class="w-full max-w-2xl mx-auto rounded-lg shadow-lg"
      />
    </div>
    
    <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-gray-900 mb-6">
      Ready To Start Your New Career
    </h2>
    
    <p class="text-lg sm:text-xl text-gray-600 mb-8 max-w-2xl mx-auto leading-relaxed">
      If you're ready for a rewarding new path in life or just to take your career to the next level sign up and get instant access to the #1 PDR course in the world.
    </p>
    
    <a 
      href="https://realworldpdr.thinkific.com/cart/add_product/445811?price_id=467088"
      class="inline-block bg-red-600 hover:bg-red-700 text-white font-bold text-lg px-8 py-4 rounded-lg transition-colors duration-300 shadow-lg hover:shadow-xl transform hover:-translate-y-1"
    >
      Enroll Now
    </a>
  </div>
</section>
