---

<section class="w-full relative bg-white">
  <!-- SVG Shape -->
  <div class="absolute bottom-0 left-0 right-0 z-10 pointer-events-none" aria-hidden="true">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1000 100" preserveAspectRatio="none" class="w-full h-auto">
      <path class="fill-primary" d="M0,6V0h1000v100L0,6z"></path>
    </svg>
  </div>
  
  <div class="max-w-[1140px] mx-auto px-0">
    <div class="flex flex-wrap lg:flex-nowrap lg:items-center">
      <!-- Left Column - Spacer -->
      <div class="w-full lg:w-1/2">
        <div class="py-20 lg:py-32"></div>
      </div>
      
      <!-- Right Column - Content -->
      <div class="w-full lg:w-1/2 px-4 lg:px-8 pb-16 lg:pb-0">
        <div class="space-y-6">
          <!-- Heading -->
          <h2 class="text-3xl lg:text-4xl font-heading text-text font-bold leading-tight">
            All Of Our Best Content, Updated Monthly
          </h2>
          
          <!-- Text Content -->
          <div class="text-base lg:text-lg text-text leading-relaxed">
            <p>
              Everything you could need to gain the knowledge to jumpstart your&nbsp;
              <a 
                href="https://realworldpdr.com/pdr-101/" 
                target="_blank" 
                rel="noopener" 
                class="text-primary hover:text-accent underline transition-colors duration-200"
              >
                PDR career
              </a>. Beginner to "super advanced" near impossible repairs covered here. Only 65 bucks gets you access to every one of our lessons including our newest and best content.
            </p>
          </div>
          
          <!-- Button -->
          <div class="text-left">
            <a 
              href="https://realworldpdr.com/real-world-pdr-monthly/" 
              class="inline-flex items-center justify-center px-6 py-3 bg-primary text-white font-medium text-sm rounded border-0 hover:bg-accent transition-all duration-300 transform hover:scale-105"
            >
              <span>Read More</span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
