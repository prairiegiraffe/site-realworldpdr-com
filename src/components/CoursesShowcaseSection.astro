---
---

<section class="relative w-full min-h-screen flex items-center bg-white">
  <div class="max-w-[1140px] mx-auto px-0 w-full">
    <div class="w-full">
      <div class="flex flex-wrap">
        <!-- Title -->
        <div class="text-center mb-8">
          <h2 class="text-4xl font-heading text-primary mb-4">Real World PDR Courses</h2>
          <div class="w-16 h-0.5 bg-primary mx-auto"></div>
        </div>

        <!-- Floating Images - Hidden on Mobile -->
        <div class="absolute top-0 left-0 w-full h-full overflow-hidden pointer-events-none hidden md:block">
          <!-- PDR Light -->
          <div class="absolute" style="top: 20%; left: 10%; transform: rotate(81deg); filter: blur(0.4px);">
            <img src="/api/files/sites/proj_dkm43vn7/1776723863099/assets/mo7rofa3b8u8ja.png" alt="pdr light" class="w-32 lg:w-48 opacity-80">
          </div>
          
          <!-- PDR Work Bench -->
          <div class="absolute" style="top: 10%; right: 15%; transform: rotate(13deg);">
            <img src="/api/files/sites/proj_dkm43vn7/1776723863099/assets/mo7rofe0zhnawv.png" alt="pdr work bench" class="w-40 lg:w-60 opacity-80">
          </div>
          
          <!-- Glue Post -->
          <div class="absolute" style="top: 40%; left: 15%; transform: rotate(23deg);">
            <img src="/api/files/sites/proj_dkm43vn7/1776723863099/assets/mo7rofvqltbnj4.png" alt="glue post" class="w-24 lg:w-32 opacity-80">
          </div>
          
          <!-- PDR Paddle -->
          <div class="absolute" style="bottom: 30%; right: 10%; transform: rotate(-5deg);">
            <img src="/api/files/sites/proj_dkm43vn7/1776723863099/assets/mo7rofsn7wfx47.png" alt="pdr paddle" class="w-48 lg:w-64 opacity-80">
          </div>
          
          <!-- PDR Hammer -->
          <div class="absolute" style="bottom: 40%; left: 20%; transform: rotate(16deg);">
            <img src="/api/files/sites/proj_dkm43vn7/1776723863099/assets/mo7rofwclevt2q.png" alt="pdr hammer" class="w-40 lg:w-56 opacity-80">
          </div>
          
          <!-- Dent Tip -->
          <div class="absolute" style="top: 30%; right: 25%; transform: rotate(-23deg);">
            <img src="/api/files/sites/proj_dkm43vn7/1776723863099/assets/mo7rogd8gdhved.png" alt="dent tip" class="w-16 lg:w-20 opacity-80">
          </div>
          
          <!-- PDR Bar -->
          <div class="absolute" style="bottom: 20%; left: 30%; transform: rotate(-2deg);">
            <img src="/api/files/sites/proj_dkm43vn7/1776723863099/assets/mo7roggrlaowg5.png" alt="pdr bar" class="w-48 lg:w-60 opacity-80">
          </div>
        </div>

        <!-- Course Cards -->
        <div class="w-full relative z-10 mt-16">
          <div class="flex flex-col md:flex-row gap-10 px-4">
            <!-- PDR 101 Course -->
            <div class="flex-1 bg-white">
              <div class="text-center">
                <figure class="mb-6">
                  <img src="/api/files/sites/proj_dkm43vn7/1776723863099/assets/mo7rogdgez7dme.jpg" alt="PDR101CourseBlurb" class="w-full max-w-md mx-auto rounded">
                </figure>
                <div class="px-6">
                  <h3 class="text-2xl font-heading text-text mb-4">PDR 101</h3>
                  <p class="text-text mb-6 leading-relaxed">
                    A Journey of 1000 miles begins with a single step. This isn't just a step, but a leap into your PDR career, several videos covering everything from your first day, to the repair of your first dent. We are told by students this is the best they've ever seen the basics explained.
                  </p>
                  <div class="text-left">
                    <a href="https://realworldpdr.com/pdr-101/" class="inline-flex items-center bg-primary hover:bg-purple-800 text-white px-6 py-2 rounded text-sm transition-all duration-300 hover:scale-105">
                      <span>See Course</span>
                    </a>
                  </div>
                </div>
              </div>
            </div>

            <!-- PDR Monthly Course -->
            <div class="flex-1 bg-white">
              <div class="text-center">
                <figure class="mb-6">
                  <img src="/api/files/sites/proj_dkm43vn7/1776723863099/assets/mo7rogyldhl27q.jpg" alt="pdr online course" class="w-full max-w-md mx-auto rounded">
                </figure>
                <div class="px-6">
                  <h3 class="text-2xl font-heading text-text mb-4">PDR Monthly</h3>
                  <p class="text-text mb-6 leading-relaxed">
                    This is absolutely everything you could need to gain the knowledge to jumpstart your PDR career. Beginner to "super advanced" near impossible repairs covered here. Only 65 bucks gets you access to every one of our lessons including our newest and best content.
                  </p>
                  <div class="text-left">
                    <a href="https://realworldpdr.com/real-world-pdr-monthly/" class="inline-flex items-center bg-primary hover:bg-purple-800 text-white px-6 py-2 rounded text-sm transition-all duration-300 hover:scale-105">
                      <span>learn more</span>
                    </a>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
