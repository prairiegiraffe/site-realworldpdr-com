---
export interface Props {
  logoUrl?: string;
  logoAlt?: string;
  logoHref?: string;
  loginText?: string;
  loginHref?: string;
  subscribeText?: string;
  subscribeHref?: string;
}

const {
  logoUrl = "https://realworldpdr.com/wp-content/uploads/2021/07/RWPDR-Logo-All-Black.png",
  logoAlt = "",
  logoHref = "https://realworldpdr.com",
  loginText = "LOG IN",
  loginHref = "https://realworldpdr.thinkific.com/users/sign_in",
  subscribeText = "SUBSCRIBE TO PDR ULTIMATE",
  subscribeHref = "https://realworldpdr.thinkific.com/cart/add_product/446304?price_id=467664"
} = Astro.props;
---

<header class="bg-white shadow-sm border-b">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center py-4">
      <!-- Logo -->
      <div class="flex-shrink-0">
        <a href={logoHref} class="block">
          <img 
            src={logoUrl} 
            alt={logoAlt}
            class="h-8 sm:h-10 w-auto"
          />
        </a>
      </div>

      <!-- Navigation Links -->
      <div class="flex items-center space-x-4 sm:space-x-6">
        <!-- Login Link -->
        <a 
          href={loginHref}
          class="text-black hover:text-gray-700 font-medium text-sm sm:text-base transition-colors duration-200"
        >
          {loginText}
        </a>

        <!-- Subscribe Button -->
        <a 
          href={subscribeHref}
          class="bg-black text-white px-3 py-2 sm:px-4 sm:py-2 rounded hover:bg-gray-800 font-medium text-xs sm:text-sm transition-colors duration-200 whitespace-nowrap"
        >
          {subscribeText}
        </a>
      </div>
    </div>
  </div>
</header>
