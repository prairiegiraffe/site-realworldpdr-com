---
---

<section class="relative">
  <!-- Background Shape -->
  <div class="absolute bottom-0 left-0 right-0 w-full h-[100px] overflow-hidden" aria-hidden="true">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1000 100" preserveAspectRatio="none" class="w-full h-full">
      <path class="fill-bg" d="M0,6V0h1000v100L0,6z"></path>
    </svg>
  </div>

  <div class="max-w-[1140px] mx-auto px-4 md:px-0">
    <div class="flex flex-col md:flex-row md:gap-10">
      <!-- Left Column - Image -->
      <div class="md:w-1/2 mb-8 md:mb-0">
        <div class="text-center">
          <img 
            loading="lazy" 
            decoding="async" 
            width="800" 
            height="534" 
            src="/api/files/sites/proj_dkm43vn7/1776723863099/assets/mo7rijlhw0ofux.png" 
            class="inline-block max-w-full h-auto" 
            alt=""
            sizes="(max-width: 800px) 100vw, 800px" 
            srcset="/api/files/sites/proj_dkm43vn7/1776723863099/assets/mo7rijlhw0ofux.png 1024w, /api/files/sites/proj_dkm43vn7/1776723863099/assets/mo7rijljp9d0tf.png 300w, /api/files/sites/proj_dkm43vn7/1776723863099/assets/mo7rijhlvbgkev.png 768w, /api/files/sites/proj_dkm43vn7/1776723863099/assets/mo7rijk72tpjq7.png 1536w, /api/files/sites/proj_dkm43vn7/1776723863099/assets/mo7rijo5fspudv.png 2048w, /api/files/sites/proj_dkm43vn7/1776723863099/assets/mo7rik2xm082n3.png 600w"
          >
        </div>
      </div>

      <!-- Right Column - Form -->
      <div class="md:w-1/2">
        <!-- Heading -->
        <h2 class="font-heading text-2xl md:text-3xl lg:text-4xl text-text mb-6 font-semibold">
          Download our free resource: The Tools You Need To Launch Your PDR Career
        </h2>

        <!-- Description -->
        <div class="mb-6">
          <p class="font-body text-text">This resource is our list of the tools we recommend for all techs starting out in PDR.</p>
        </div>

        <!-- Benefits List -->
        <ul class="mb-8 space-y-3">
          <li class="flex items-center">
            <span class="mr-3 text-accent">
              <i class="fas fa-check" aria-hidden="true"></i>
            </span>
            <span class="font-body text-text">The tools we use and trust</span>
          </li>
          <li class="flex items-center">
            <span class="mr-3 text-accent">
              <i class="fas fa-check" aria-hidden="true"></i>
            </span>
            <span class="font-body text-text">Everything you need to get started</span>
          </li>
          <li class="flex items-center">
            <span class="mr-3 text-accent">
              <i class="fas fa-check" aria-hidden="true"></i>
            </span>
            <span class="font-body text-text">No BS, just the good stuff</span>
          </li>
        </ul>

        <!-- Form -->
        <form class="space-y-4" method="post" name="Tool List Subscribe">
          <input type="hidden" name="post_id" value="573">
          <input type="hidden" name="form_id" value="034c9bc">
          <input type="hidden" name="referer_title" value="">

          <!-- Name Field -->
          <div class="flex flex-col">
            <label for="form-field-name" class="font-body text-text mb-2 font-medium">
              Name
            </label>
            <input 
              type="text" 
              name="form_fields[name]" 
              id="form-field-name" 
              class="w-full px-4 py-3 border border-gray-300 rounded-[4px] font-body text-text placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary"
              placeholder="First Name" 
              required
            >
          </div>

          <!-- Email Field -->
          <div class="flex flex-col">
            <label for="form-field-email" class="font-body text-text mb-2 font-medium">
              Email
            </label>
            <input 
              type="email" 
              name="form_fields[email]" 
              id="form-field-email" 
              class="w-full px-4 py-3 border border-gray-300 rounded-[4px] font-body text-text placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary"
              placeholder="Email" 
              required
            >
          </div>

          <!-- Submit Button -->
          <div class="pt-4">
            <button 
              type="submit" 
              class="w-full bg-primary text-white font-body font-semibold px-6 py-3 rounded-[4px] hover:bg-opacity-90 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2"
            >
              SEND ME THE GUIDE!
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</section>
