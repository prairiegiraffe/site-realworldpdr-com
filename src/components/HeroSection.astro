---
export interface Props {
  heading?: string;
  description?: string;
  buttonText?: string;
  buttonHref?: string;
}

const {
  heading = "Online paintless dent repair training",
  description = "Quality online video courses that teach you what you need to know so you can have the career you've always dreamed of in PDR.",
  buttonText = "SUBSCRIBE TO PDR ULTIMATE",
  buttonHref = "https://realworldpdr.thinkific.com/cart/add_product/446304?price_id=467664"
} = Astro.props;
---

<section class="bg-gradient-to-br from-blue-900 via-blue-800 to-blue-700 min-h-screen flex items-center justify-center px-4 py-16">
  <div class="max-w-4xl mx-auto text-center">
    <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6 leading-tight">
      {heading}
    </h1>
    
    <p class="text-xl md:text-2xl text-blue-100 mb-8 max-w-3xl mx-auto leading-relaxed">
      {description}
    </p>
    
    <a 
      href={buttonHref}
      class="inline-block bg-orange-500 hover:bg-orange-600 text-white font-bold text-lg px-8 py-4 rounded-lg transition-colors duration-300 transform hover:scale-105 shadow-lg"
    >
      {buttonText}
    </a>
  </div>
</section>
