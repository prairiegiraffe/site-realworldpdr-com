---
export interface Props {
  id?: string;
}

const { id = "process-steps" } = Astro.props;
---

<section id={id} class="py-16 px-4 bg-white">
  <div class="max-w-4xl mx-auto text-center">
    <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-12">
      Learning PDR is easy as…
    </h2>
    
    <div class="space-y-12">
      <!-- Step 1 -->
      <div class="flex flex-col items-center">
        <div class="w-16 h-16 bg-blue-600 rounded-full flex items-center justify-center mb-6">
          <span class="text-2xl font-bold text-white">1</span>
        </div>
        <h3 class="text-xl md:text-2xl font-semibold text-gray-900 max-w-2xl">
          Click "Get Instant Access" and sign up for the course that fits you.
        </h3>
      </div>
      
      <!-- Step 2 -->
      <div class="flex flex-col items-center">
        <div class="w-16 h-16 bg-blue-600 rounded-full flex items-center justify-center mb-6">
          <span class="text-2xl font-bold text-white">2</span>
        </div>
        <h3 class="text-xl md:text-2xl font-semibold text-gray-900 max-w-2xl">
          Practice and perfect the new skills you're learning with each module.
        </h3>
      </div>
      
      <!-- Step 3 -->
      <div class="flex flex-col items-center">
        <div class="w-16 h-16 bg-blue-600 rounded-full flex items-center justify-center mb-6">
          <span class="text-2xl font-bold text-white">3</span>
        </div>
        <h3 class="text-xl md:text-2xl font-semibold text-gray-900 max-w-2xl">
          Have the career you've always wanted.
        </h3>
      </div>
    </div>
    
    <div class="mt-16">
      <a 
        href="https://realworldpdr.thinkific.com/cart/add_product/446304?price_id=467664"
        class="inline-block bg-red-600 hover:bg-red-700 text-white font-bold py-4 px-8 text-lg rounded-lg transition-colors duration-200 transform hover:scale-105"
      >
        SUBSCRIBE TO PDR ULTIMATE
      </a>
    </div>
  </div>
</section>
