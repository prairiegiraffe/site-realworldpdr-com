---
export interface Props {
  className?: string;
}

const { className = '' } = Astro.props;
---

<section id="courses" class={`py-16 px-4 bg-white ${className}`}>
  <div class="max-w-6xl mx-auto">
    <h2 class="text-3xl md:text-4xl font-bold text-center text-gray-900 mb-12">
      Real World PDR Courses
    </h2>

    <!-- PDR Tools Grid -->
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-7 gap-4 mb-16">
      <div class="flex justify-center">
        <img 
          src="/api/files/sites/proj_dkm43vn7/1776723863099/assets/mo7rofa3b8u8ja.png" 
          alt="pdr light"
          class="w-full h-auto max-w-20 object-contain"
        />
      </div>
      <div class="flex justify-center">
        <img 
          src="/api/files/sites/proj_dkm43vn7/1776723863099/assets/mo7rofe0zhnawv.png" 
          alt="pdr work bench"
          class="w-full h-auto max-w-20 object-contain"
        />
      </div>
      <div class="flex justify-center">
        <img 
          src="/api/files/sites/proj_dkm43vn7/1776723863099/assets/mo7rofvqltbnj4.png" 
          alt="glue post"
          class="w-full h-auto max-w-20 object-contain"
        />
      </div>
      <div class="flex justify-center">
        <img 
          src="/api/files/sites/proj_dkm43vn7/1776723863099/assets/mo7rofsn7wfx47.png" 
          alt="pdr paddle"
          class="w-full h-auto max-w-20 object-contain"
        />
      </div>
      <div class="flex justify-center">
        <img 
          src="/api/files/sites/proj_dkm43vn7/1776723863099/assets/mo7rofwclevt2q.png" 
          alt="pdr hammer"
          class="w-full h-auto max-w-20 object-contain"
        />
      </div>
      <div class="flex justify-center">
        <img 
          src="/api/files/sites/proj_dkm43vn7/1776723863099/assets/mo7rogd8gdhved.png" 
          alt="dent tip"
          class="w-full h-auto max-w-20 object-contain"
        />
      </div>
      <div class="flex justify-center">
        <img 
          src="/api/files/sites/proj_dkm43vn7/1776723863099/assets/mo7roggrlaowg5.png" 
          alt="pdr bar"
          class="w-full h-auto max-w-20 object-contain"
        />
      </div>
    </div>

    <!-- Courses Grid -->
    <div class="grid md:grid-cols-2 gap-12 lg:gap-16">
      
      <!-- PDR 101 Course -->
      <div class="text-center">
        <div class="mb-6">
          <img 
            src="/api/files/sites/proj_dkm43vn7/1776723863099/assets/mo7rogdgez7dme.jpg" 
            alt="PDR101CourseBlurb"
            class="w-full rounded-lg shadow-lg"
          />
        </div>
        <h3 class="text-2xl font-bold text-gray-900 mb-4">PDR 101</h3>
        <p class="text-gray-600 text-lg leading-relaxed mb-6">
          A Journey of 1000 miles begins with a single step. This isn't just a step, but a leap into your PDR career, several videos covering everything from your first day, to the repair of your first dent. We are told by students this is the best they've ever seen the basics explained.
        </p>
        <a 
          href="https://realworldpdr.com/pdr-101/" 
          class="inline-block bg-blue-600 hover:bg-blue-700 text-white font-semibold px-8 py-3 rounded-lg transition-colors duration-300"
        >
          See Course
        </a>
      </div>

      <!-- PDR Monthly Course -->
      <div class="text-center">
        <div class="mb-6">
          <img 
            src="/api/files/sites/proj_dkm43vn7/1776723863099/assets/mo7rogyldhl27q.jpg" 
            alt="pdr online course"
            class="w-full rounded-lg shadow-lg"
          />
        </div>
        <h3 class="text-2xl font-bold text-gray-900 mb-4">PDR Monthly</h3>
        <p class="text-gray-600 text-lg leading-relaxed mb-6">
          This is absolutely everything you could need to gain the knowledge to jumpstart your PDR career. Beginner to "super advanced" near impossible repairs covered here. Only 65 bucks gets you access to every one of our lessons including our newest and best content.
        </p>
        <a 
          href="https://realworldpdr.com/real-world-pdr-monthly/" 
          class="inline-block bg-blue-600 hover:bg-blue-700 text-white font-semibold px-8 py-3 rounded-lg transition-colors duration-300"
        >
          learn more
        </a>
      </div>

    </div>
  </div>
</section>
