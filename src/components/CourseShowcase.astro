<section class="py-20 px-4" style="background-color: #f5f5f5;">
  <div class="max-w-4xl mx-auto">
    <div class="text-center mb-12">
      <h2 class="text-3xl font-bold text-black mb-4">Real World PDR Courses</h2>
      <div class="w-20 h-1 bg-gold mx-auto"></div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      <!-- Card 1: PDR 101 -->
      <div class="bg-white rounded overflow-hidden shadow-sm">
        <img
          src="/api/files/sites/proj_dkm43vn7/1776723863099/assets/mo7rogdgez7dme.jpg"
          alt="PDR 101 Course"
          class="w-full rounded-t"
        />
        <div class="p-6">
          <h3 class="text-xl font-bold text-black mb-3">PDR 101</h3>
          <p class="text-gray-body mb-4">
            A Journey of 1000 miles begins with a single step. This isn't just a step, but a leap into your PDR career.
          </p>
          <a
            href="/pdr-101"
            class="bg-gold text-white font-bold px-8 py-3 rounded inline-block hover:opacity-90 transition-opacity"
          >
            See Course
          </a>
        </div>
      </div>

      <!-- Card 2: PDR Monthly -->
      <div class="bg-white rounded overflow-hidden shadow-sm">
        <img
          src="/api/files/sites/proj_dkm43vn7/1776723863099/assets/mo7rogyldhl27q.jpg"
          alt="PDR Monthly Course"
          class="w-full rounded-t"
        />
        <div class="p-6">
          <h3 class="text-xl font-bold text-black mb-3">PDR Monthly</h3>
          <p class="text-gray-body mb-4">
            This is absolutely everything you could need to gain the knowledge to jumpstart your PDR career.
          </p>
          <a
            href="/pdr-ultimate"
            class="bg-gold text-white font-bold px-8 py-3 rounded inline-block hover:opacity-90 transition-opacity"
          >
            learn more
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
