---
import Layout from '../layouts/Layout.astro';
---

<section class="py-16 bg-white">
  <div class="container mx-auto max-w-5xl px-4">
    <div class="flex flex-wrap items-center -mx-2 lg:-mx-4">
      <div class="w-full lg:w-1/2 px-2 lg:px-4 mb-8 lg:mb-0">
        <div class="lg:pr-8">
          <h2 class="text-3xl lg:text-4xl font-bold text-text mb-4">PDR 101 Workshop</h2>
          <p class="text-lg text-text">Come learn everything you need to start doing PDR at this two-day event.</p>
        </div>
      </div>
      <div class="w-full lg:w-1/2 px-2 lg:px-4">
        <div class="text-center">
          <a 
            href="https://realworldpdr.com/pdr-101-workshop/" 
            class="inline-block bg-primary text-white px-6 py-3 rounded transition-all duration-300 hover:scale-105 hover:bg-opacity-90 font-medium uppercase tracking-wide"
          >
            learn more
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
