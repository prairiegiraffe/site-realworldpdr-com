---
---

<section class="py-20 md:py-28 px-4" id="contact">
  <div class="max-w-6xl mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
      <div>
        <img
          src="https://devtools.prairiegiraffe.com/api/files/sites/proj_dkm43vn7/1776723863099/assets/mo7rijlhw0ofux.png"
          alt="The Tools You Need To Launch Your PDR Career guide"
          class="w-full max-w-lg mx-auto"
          loading="lazy"
        />
      </div>

      <div class="md:pr-10 md:pl-10">
        <h2 class="text-2xl md:text-3xl font-bold text-black mb-4">
          Download our free resource: The Tools You Need To Launch Your PDR Career
        </h2>
        <p class="text-gray-body mb-4">
          This resource is our list of the tools we recommend for all techs starting out in PDR.
        </p>

        <ul class="mb-6 space-y-2">
          <li class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-gold flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
            <span class="text-gray-body">The tools we use and trust</span>
          </li>
          <li class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-gold flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
            <span class="text-gray-body">Everything you need to get started</span>
          </li>
          <li class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-gold flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
            <span class="text-gray-body">No BS, just the good stuff</span>
          </li>
        </ul>

        <form name="Tool List Subscribe">
          <div class="mb-3">
            <label for="lead-name" class="block text-sm font-bold text-black mb-1">Name</label>
            <input
              type="text"
              id="lead-name"
              name="name"
              placeholder="First Name"
              required
              class="w-full border border-gray-300 rounded px-4 py-2 text-gray-body"
            />
          </div>
          <div class="mb-3">
            <label for="lead-email" class="block text-sm font-bold text-black mb-1">Email</label>
            <input
              type="email"
              id="lead-email"
              name="email"
              placeholder="Email"
              required
              class="w-full border border-gray-300 rounded px-4 py-2 text-gray-body"
            />
          </div>
          <button
            type="submit"
            class="bg-[#F6DB0F] text-white font-bold uppercase w-full py-3 rounded hover:bg-[#f98608] transition-colors"
          >
            Send Me the Guide!
          </button>
        </form>
      </div>
    </div>
  </div>
</section>

