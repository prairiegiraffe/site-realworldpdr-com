---
---

<header class="bg-white py-4 px-4 md:px-8 relative z-50">
  <div class="flex justify-between items-center max-w-7xl mx-auto">
    <!-- Logo -->
    <a href="/" class="shrink-0">
      <img
        src="https://realworldpdr.com/wp-content/uploads/2021/07/RWPDR-Logo-All-Black.png"
        alt="Real World PDR"
        class="max-w-[200px] md:max-w-[250px] h-auto"
      />
    </a>

    <!-- Desktop Nav -->
    <div class="hidden md:flex items-center gap-6">
      <a
        href="https://realworldpdr.thinkific.com/users/sign_in"
        class="text-black font-bold uppercase text-sm tracking-wide hover:opacity-80"
      >
        Log In
      </a>
      <a
        href="https://realworldpdr.thinkific.com/cart/add_product/446304?price_id=467664"
        class="bg-gold text-white font-bold uppercase text-sm px-5 py-2 rounded hover:opacity-90 inline-block"
      >
        Subscribe to PDR Ultimate
      </a>
    </div>

    <!-- Mobile: Log In + Hamburger -->
    <div class="flex items-center gap-4 md:hidden">
      <a
        href="https://realworldpdr.thinkific.com/users/sign_in"
        class="text-black font-bold uppercase text-sm tracking-wide hover:opacity-80"
      >
        Log In
      </a>
      <button
        id="mobile-menu-btn"
        type="button"
        class="text-black focus:outline-none"
        aria-label="Toggle mobile menu"
        aria-expanded="false"
      >
        <svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Dropdown Nav -->
  <nav
    id="mobile-nav"
    class="hidden md:hidden absolute left-0 right-0 top-full bg-white shadow-lg border-t border-gray-100 z-40"
  >
    <ul class="flex flex-col py-4 px-4">
      <!-- PDR Courses with sub-items -->
      <li>
        <button
          id="mobile-courses-toggle"
          type="button"
          class="w-full flex justify-between items-center py-3 text-black font-bold uppercase text-sm tracking-wide"
        >
          PDR Courses
          <svg class="w-4 h-4 transition-transform" id="mobile-courses-arrow" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
        <ul id="mobile-courses-sub" class="hidden pl-4 pb-2">
          <li>
            <a href="/real-world-pdr-courses" class="block py-2 text-gray-body text-sm uppercase tracking-wide hover:text-black">
              All Courses
            </a>
          </li>
          <li>
            <a href="/pdr-ultimate" class="block py-2 text-gray-body text-sm uppercase tracking-wide hover:text-black">
              PDR Monthly
            </a>
          </li>
          <li>
            <a href="/pdr-101" class="block py-2 text-gray-body text-sm uppercase tracking-wide hover:text-black">
              PDR 101
            </a>
          </li>
        </ul>
      </li>
      <li>
        <a href="#contact" class="block py-3 text-black font-bold uppercase text-sm tracking-wide hover:opacity-80">
          Contact Us
        </a>
      </li>
      <li>
        <a
          href="https://realworldpdr.thinkific.com/users/sign_in"
          class="block py-3 text-black font-bold uppercase text-sm tracking-wide hover:opacity-80"
        >
          Sign In
        </a>
      </li>
      <li class="pt-2">
        <a
          href="https://realworldpdr.thinkific.com/cart/add_product/446304?price_id=467664"
          class="block text-center bg-gold text-white font-bold uppercase text-sm px-5 py-3 rounded hover:opacity-90"
        >
          Subscribe to PDR Ultimate
        </a>
      </li>
    </ul>
  </nav>
</header>

<script>
  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileNav = document.getElementById('mobile-nav');
  const coursesToggle = document.getElementById('mobile-courses-toggle');
  const coursesSub = document.getElementById('mobile-courses-sub');
  const coursesArrow = document.getElementById('mobile-courses-arrow');

  if (menuBtn && mobileNav) {
    menuBtn.addEventListener('click', () => {
      const isOpen = !mobileNav.classList.contains('hidden');
      mobileNav.classList.toggle('hidden');
      menuBtn.setAttribute('aria-expanded', String(!isOpen));
    });
  }

  if (coursesToggle && coursesSub && coursesArrow) {
    coursesToggle.addEventListener('click', () => {
      coursesSub.classList.toggle('hidden');
      coursesArrow.classList.toggle('rotate-180');
    });
  }
</script>
