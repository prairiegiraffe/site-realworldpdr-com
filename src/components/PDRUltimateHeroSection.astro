---

<section class="relative bg-gradient-to-r from-primary/10 to-accent/10 min-h-screen flex items-center">
  <div class="absolute inset-0 bg-gradient-to-br from-primary/20 via-transparent to-accent/10"></div>
  <div class="container mx-auto px-4 max-w-[1020px]">
    <div class="grid lg:grid-cols-2 gap-8 lg:gap-12 items-center">
      <!-- Text Content Column -->
      <div class="order-2 lg:order-1 text-center lg:text-left">
        <h1 class="font-heading text-4xl md:text-5xl lg:text-6xl font-bold text-text mb-6">
          Real World <br>PDR Ultimate
        </h1>
        
        <!-- Divider -->
        <div class="w-24 h-1 bg-primary mx-auto lg:mx-0 mb-6"></div>
        
        <p class="text-lg md:text-xl text-text/80 mb-8 leading-relaxed">
          This is absolutely everything you could need to gain the knowledge to jumpstart your PDR career. Beginner to "super advanced" near impossible repairs covered here. Get access to every one of our lessons including our newest and best content.
        </p>
        
        <div class="text-center lg:text-left">
          <a 
            href="https://realworldpdr.thinkific.com/cart/add_product/446304?price_id=467664"
            class="inline-block bg-primary hover:bg-primary/90 text-white font-semibold px-8 py-4 rounded transition-all duration-300 transform hover:scale-105 hover:shadow-lg"
          >
            Buy Course
          </a>
        </div>
      </div>
      
      <!-- Video Column -->
      <div class="order-1 lg:order-2 relative">
        <div class="relative rounded-lg overflow-hidden shadow-2xl">
          <video 
            class="w-full h-auto" 
            src="/api/files/sites/proj_dkm43vn7/1776723863099/assets/mo7ro1xj0mcepu.mp4" 
            controls 
            preload="metadata" 
            controlslist="nodownload"
            poster="/api/files/sites/proj_dkm43vn7/1776723863099/assets/mo7ro15rqzi7aa.png"
          ></video>
          
          <!-- Custom Play Button Overlay -->
          <div 
            class="absolute inset-0 flex items-center justify-center bg-black/30 opacity-0 hover:opacity-100 transition-opacity duration-300 cursor-pointer video-overlay"
            style="background-image: url('/api/files/sites/proj_dkm43vn7/1776723863099/assets/mo7ro15rqzi7aa.png'); background-size: cover; background-position: center;"
          >
            <div class="play-button">
              <div class="w-20 h-20 bg-white/90 rounded-full flex items-center justify-center shadow-xl hover:scale-110 transition-transform duration-300">
                <div class="w-0 h-0 border-l-[16px] border-l-primary border-y-[12px] border-y-transparent ml-1"></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const videoOverlay = document.querySelector('.video-overlay');
    const video = document.querySelector('video');
    
    if (videoOverlay && video) {
      // Initially show the overlay
      videoOverlay.style.opacity = '1';
      
      videoOverlay.addEventListener('click', function() {
        video.play();
        videoOverlay.style.opacity = '0';
        setTimeout(() => {
          videoOverlay.style.display = 'none';
        }, 300);
      });
      
      video.addEventListener('play', function() {
        videoOverlay.style.opacity = '0';
        setTimeout(() => {
          videoOverlay.style.display = 'none';
        }, 300);
      });
      
      video.addEventListener('pause', function() {
        if (video.currentTime === 0) {
          videoOverlay.style.display = 'flex';
          setTimeout(() => {
            videoOverlay.style.opacity = '1';
          }, 10);
        }
      });
    }
  });
</script>
