---
interface Props {
  buttonUrl?: string;
  backgroundImage?: string;
}
const {
  buttonUrl = "https://realworldpdr.thinkific.com/cart/add_product/446304?price_id=467664",
  backgroundImage = "/api/files/sites/proj_dkm43vn7/1776723863099/assets/mo7ye9h42cusx6.jpg",
} = Astro.props;
---

<section class="relative pt-16 md:pt-24 pb-16 md:pb-24 px-4 md:px-6">
  <!-- Bottom SVG shape divider -->
  <div class="absolute bottom-0 left-0 w-full overflow-hidden leading-none z-10 pointer-events-none" aria-hidden="true">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1000 100" preserveAspectRatio="none" class="w-full h-[30px] scale-x-[-1]">
      <path class="fill-[#e5ca00]" d="M0,6V0h1000v100L0,6z"></path>
    </svg>
  </div>

  <div class="max-w-container mx-auto">
    <div class="flex flex-col md:flex-row overflow-hidden">
      <!-- Left: Background Image -->
      <div
        class="w-full md:w-1/2 md:min-w-[380px] lg:min-w-[500px] min-h-[250px] md:min-h-[450px] bg-cover bg-center transition-transform duration-[1500ms] hover:scale-105"
        style={`background-image: url('${backgroundImage}');`}
        role="img"
        aria-label="Red car dent free"
      >
      </div>
      <!-- Right: Content -->
      <div class="w-full md:w-1/2 bg-black flex items-center">
        <div class="p-8 md:p-12 lg:p-16 text-left">
          <h2 class="font-heading text-3xl md:text-[45px] font-semibold tracking-wider text-white leading-tight mb-6">
            Ready To Start<br />Your New Career
          </h2>
          <p class="text-white text-[17px] font-light leading-[1.8] tracking-wider mb-6">
            If you're ready for a rewarding new path in life or just to take your career to the next level sign up and get instant access to the #1 PDR course in the world.
          </p>
          <div>
            <a
              href={buttonUrl}
              class="inline-block text-[#e5ca00] border border-[#e5ca00] text-[15px] font-semibold uppercase px-6 py-2 hover:text-black hover:bg-white hover:border-white transition-all duration-300"
            >
              Enroll Now
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
