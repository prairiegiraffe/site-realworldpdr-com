---
export interface Props {
  id?: string;
}

const { id = "hero" } = Astro.props;
---

<section id={id} class="relative min-h-screen bg-gradient-to-br from-slate-900 to-slate-800 text-white overflow-hidden">
  <!-- Background overlay -->
  <div class="absolute inset-0 bg-black/20"></div>
  
  <!-- Content container -->
  <div class="relative z-10 container mx-auto px-4 py-16 min-h-screen flex flex-col justify-center items-center text-center">
    
    <!-- Main heading -->
    <h1 class="text-4xl md:text-6xl lg:text-7xl font-bold mb-6 leading-tight">
      Real World PDR
    </h1>
    
    <!-- Description text -->
    <p class="text-lg md:text-xl lg:text-2xl max-w-4xl mb-12 text-slate-200 leading-relaxed">
      Real World PDR Training like never seen before. No Gimmicks, NO BS. Just Real Training brought to you by industry leading Master Technician, Jim Mitchell
    </p>
    
    <!-- Video container -->
    <div class="relative w-full max-w-4xl mb-12 rounded-xl overflow-hidden shadow-2xl">
      <div class="relative aspect-video bg-slate-900">
        <img 
          src="/api/files/sites/proj_dkm43vn7/1776723863099/assets/mo7rogxzgv9l4p.jpg" 
          alt="Real World PDR Training Video" 
          class="w-full h-full object-cover"
        />
        <button 
          class="absolute inset-0 flex items-center justify-center bg-black/30 hover:bg-black/20 transition-all duration-300 group"
          onclick="playVideo()"
        >
          <div class="w-16 h-16 md:w-20 md:h-20 bg-red-600 rounded-full flex items-center justify-center group-hover:bg-red-500 transition-colors duration-300">
            <svg class="w-6 h-6 md:w-8 md:h-8 text-white ml-1" fill="currentColor" viewBox="0 0 20 20">
              <path d="M6.3 2.841A1.5 1.5 0 004 4.11V15.89a1.5 1.5 0 002.3 1.269l9.344-5.89a1.5 1.5 0 000-2.538L6.3 2.84z"/>
            </svg>
          </div>
        </button>
      </div>
    </div>
    
    <!-- CTA Button -->
    <a 
      href="#whatisrealworld"
      class="inline-block px-8 py-4 bg-red-600 hover:bg-red-500 text-white font-semibold text-lg rounded-lg transition-all duration-300 hover:scale-105 hover:shadow-lg"
    >
      Learn More
    </a>
    
  </div>
  
  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 transform -translate-x-1/2 animate-bounce">
    <svg class="w-6 h-6 text-white/60" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/>
    </svg>
  </div>
</section>

<script>
  function playVideo() {
    const videoUrl = 'https://youtu.be/a-NReZm1SA8';
    window.open(videoUrl, '_blank');
  }
</script>
