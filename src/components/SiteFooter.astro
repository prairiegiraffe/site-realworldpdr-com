---
// SiteFooter — shared across all pages
---

<footer class="relative bg-secondary text-text">
  <!-- SVG shape divider (angled, pointing up on left) -->
  <div class="absolute top-0 left-0 w-full overflow-hidden leading-none -translate-y-[99%]">
    <svg
