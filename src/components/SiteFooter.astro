          <ul class="absolute bottom-full left-1/2 -translate-x-1/2 mb-2 bg-white rounded shadow-lg py-2 min-w-[160px] hidden footer-dropdown-menu z-10">
            <li>
              <a href="/real-world-pdr-courses" class="block px-4 py-2 text-sm text-text hover:bg-secondary transition-colors">
                ALL COURSES
              </a>
            </li>
            <li>
              <a href="/pdr-ultimate" class="block px-4 py-2 text-sm text-text hover:bg-secondary transition-colors">
                PDR MONTHLY
              </a>
            </li>
            <li>
              <a href="/pdr-101" class="block px-4 py-2 text-sm text-text hover:bg-secondary transition-colors">
                PDR 101
              </a>
            </li>
          </ul>
        </li>
        <li>
          <a href="#" class="text-text hover:text-primary transition-colors py-2 inline-block">
            RESPECT THE CROWN
          </a>
        </li>
        <li>
          <a href="#" class="text-text hover:text-primary transition-colors py-2 inline-block">
            CONTACT US
          </a>
        </li>
        <li>
          <a href="https://realworldpdr.thinkific.com/users/sign_in" class="text-text hover:text-primary transition-colors py-2 inline-block">
            SIGN IN
          </a>
        </li>
      </ul>
    </nav>

    <!-- Legal links -->
    <div class="flex items-center justify-center gap-4 text-xs text-gray-500 mb-6">
      <a href="/privacy-policy" class="hover:text-primary transition-colors">Privacy Policy</a>
      <span aria-hidden="true">|</span>
      <a href="/terms" class="hover:text-primary transition-colors">Terms</a>
    </div>

    <!-- Bottom row -->
    <div class="border-t border-gray-300 pt-4 flex flex-col md:flex-row items-center justify-between gap-2 text-xs text-gray-500">
      <p>
        Real World PDR &copy; 2023 | <a href="https://jmdentrepair.com" target="_blank" rel="noopener noreferrer" class="hover:text-primary transition-colors">JM Dent Repair LLC</a>
      </p>
      <p>
        Made by <a href="https://prairiegiraffe.com" target="_blank" rel="nofollow noopener noreferrer" class="hover:text-primary transition-colors">Prairie Giraffe</a>
      </p>
    </div>
  </div>
</footer>

<script>
  // Footer dropdown toggle
  const dropdownBtns = document.querySelectorAll('.footer-dropdown-btn');
  dropdownBtns.forEach((btn) => {
    const menu = btn.nextElementSibling as HTMLElement | null;
    if (!menu) return;

    btn.addEventListener('click', () => {
      const isOpen = !menu.classList.contains('hidden');
      // Close all other dropdowns first
      document.querySelectorAll('.footer-dropdown-menu').forEach((m) => {
        m.classList.add('hidden');
      });
      if (!isOpen) {
        menu.classList.remove('hidden');
      }
    });
  });

  // Close dropdown when clicking outside
  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    if (!target.closest('.footer-dropdown-btn') && !target.closest('.footer-dropdown-menu')) {
      document.querySelectorAll('.footer-dropdown-menu').forEach((m) => {
        m.classList.add('hidden');
      });
    }
  });
</script>
