---
<section class="relative min-h-screen flex items-center bg-white">
  <div class="absolute inset-0 bg-gradient-to-r from-primary/5 to-transparent"></div>
  
  <div class="container mx-auto px-4 max-w-screen-lg">
    <div class="flex flex-col lg:flex-row items-center gap-8 lg:gap-12">
      <!-- Left Column - Content -->
      <div class="flex-1 text-left lg:pr-8">
        <h1 class="text-4xl lg:text-5xl font-heading font-bold text-text mb-6">
          PDR 101
        </h1>
        
        <!-- Divider -->
        <div class="w-16 h-0.5 bg-primary mb-6"></div>
        
        <h2 class="text-2xl lg:text-3xl font-heading font-semibold text-text mb-6">
          One Time $55 USD
        </h2>
        
        <p class="text-lg text-text/80 leading-relaxed mb-8">
          A Journey of 1000 miles begins with a single step. This isn't just a step, but a leap into your PDR career, several videos covering everything from your first day, to the repair of your first dent. We are told by students this is the best they've ever seen the basics explained.
        </p>
        
        <div class="flex justify-start md:justify-center lg:justify-start">
          <a 
            href="https://realworldpdr.thinkific.com/cart/add_product/445811?price_id=467088"
            class="inline-flex items-center px-6 py-3 bg-primary text-white font-semibold rounded transition-all duration-300 hover:bg-primary/90 hover:shadow-lg transform hover:scale-105"
          >
            <span>Buy Course</span>
          </a>
        </div>
      </div>
      
      <!-- Right Column - Video -->
      <div class="flex-1 w-full max-w-lg lg:max-w-none">
        <div class="relative w-full aspect-video rounded-lg overflow-hidden bg-black shadow-xl">
          <video 
            class="w-full h-full object-cover"
            src="/api/files/sites/proj_dkm43vn7/1776723863099/assets/mo7ro1xj0mcepu.mp4"
            controls
            preload="metadata"
            controlsList="nodownload"
            poster="/api/files/sites/proj_dkm43vn7/1776723863099/assets/mo7rp5z6cwdrp9.png"
          >
          </video>
          
          <!-- Custom Play Overlay -->
          <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
            <div class="w-16 h-16 bg-white/20 backdrop-blur-sm rounded-full flex items-center justify-center opacity-0 hover:opacity-100 transition-opacity duration-300">
              <svg class="w-8 h-8 text-white ml-1" fill="currentColor" viewBox="0 0 20 20">
                <path d="M8 5v10l8-5-8-5z"/>
              </svg>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  // Video play overlay functionality
  document.addEventListener('DOMContentLoaded', function() {
    const videos = document.querySelectorAll('video');
    
    videos.forEach(video => {
      const overlay = video.parentElement.querySelector('.absolute.inset-0');
      
      if (overlay) {
        overlay.addEventListener('click', function() {
          if (video.paused) {
            video.play();
          } else {
            video.pause();
          }
        });
        
        video.addEventListener('play', function() {
          overlay.style.pointerEvents = 'none';
          overlay.style.opacity = '0';
        });
        
        video.addEventListener('pause', function() {
          overlay.style.pointerEvents = 'auto';
          overlay.style.opacity = '1';
        });
      }
    });
  });
</script>
---
