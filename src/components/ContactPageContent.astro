---
---

<!-- Hero -->
<section class="bg-black py-16 px-4">
  <div class="max-w-container mx-auto">
    <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">Contact Us</h1>
    <div class="w-20 h-1 bg-gold my-4"></div>
    <p class="text-white/90 text-lg max-w-2xl leading-relaxed">
      Have a question about our courses, in-person training, or anything PDR? We'd love to hear from you.
    </p>
  </div>
</section>

<!-- Contact Form + Info -->
<section class="py-16 md:py-20 px-4" id="contact">
  <div class="max-w-container mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-5 gap-12">

      <!-- Form Column -->
      <div class="lg:col-span-3">
        <h2 class="text-2xl font-bold text-black mb-6">Send Us a Message</h2>
        <form data-devtools-form data-form-type="contact" method="post" class="space-y-5">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
            <div>
              <label for="contact-name" class="block text-sm font-bold text-black mb-1.5">Name <span class="text-red-500">*</span></label>
              <input
                type="text"
                id="contact-name"
                name="name"
                required
                placeholder="Your name"
                class="w-full border border-gray-300 rounded px-4 py-3 text-gray-body focus:outline-none focus:border-gold focus:ring-1 focus:ring-gold"
              />
            </div>
            <div>
              <label for="contact-email" class="block text-sm font-bold text-black mb-1.5">Email <span class="text-red-500">*</span></label>
              <input
                type="email"
                id="contact-email"
                name="email"
                required
                placeholder="you@email.com"
                class="w-full border border-gray-300 rounded px-4 py-3 text-gray-body focus:outline-none focus:border-gold focus:ring-1 focus:ring-gold"
              />
            </div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
            <div>
              <label for="contact-phone" class="block text-sm font-bold text-black mb-1.5">Phone</label>
              <input
                type="tel"
                id="contact-phone"
                name="phone"
                placeholder="(555) 555-5555"
                class="w-full border border-gray-300 rounded px-4 py-3 text-gray-body focus:outline-none focus:border-gold focus:ring-1 focus:ring-gold"
              />
            </div>
            <div>
              <label for="contact-interest" class="block text-sm font-bold text-black mb-1.5">I'm interested in</label>
              <select
                id="contact-interest"
                name="custom_fields[interest]"
                class="w-full border border-gray-300 rounded px-4 py-3 text-gray-body focus:outline-none focus:border-gold focus:ring-1 focus:ring-gold bg-white"
              >
                <option value="">Select an option...</option>
                <option value="Online Courses">Online Courses</option>
                <option value="In-Person Training">In-Person Training</option>
                <option value="PDR 101">PDR 101</option>
                <option value="PDR Monthly">PDR Monthly</option>
                <option value="General Question">General Question</option>
              </select>
            </div>
          </div>

          <div>
            <label for="contact-message" class="block text-sm font-bold text-black mb-1.5">Message <span class="text-red-500">*</span></label>
            <textarea
              id="contact-message"
              name="message"
              required
              rows="5"
              placeholder="Tell us how we can help you..."
              class="w-full border border-gray-300 rounded px-4 py-3 text-gray-body focus:outline-none focus:border-gold focus:ring-1 focus:ring-gold resize-y"
            ></textarea>
          </div>

          <button
            type="submit"
            class="bg-gold text-white font-semibold uppercase text-base px-10 py-3 rounded tracking-wider hover:bg-[#f98608] transition-colors"
          >
            Send Message
          </button>
        </form>
      </div>

      <!-- Info Column -->
      <div class="lg:col-span-2">
        <h2 class="text-2xl font-bold text-black mb-6">Get in Touch</h2>

        <div class="bg-[#f9f9f9] rounded-lg p-6 md:p-8 space-y-6">
          <!-- Email -->
          <div class="flex items-start gap-3">
            <svg class="w-6 h-6 text-gold flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z" />
            </svg>
            <div>
              <p class="font-bold text-black text-sm uppercase tracking-wide mb-1">Email</p>
              <a href="mailto:Jim@jmdentrepair.com" class="text-gray-body hover:text-gold transition-colors">
                Jim@jmdentrepair.com
              </a>
            </div>
          </div>

          <!-- Address -->
          <div class="flex items-start gap-3">
            <svg class="w-6 h-6 text-gold flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5S10.62 6.5 12 6.5s2.5 1.12 2.5 2.5S13.38 11.5 12 11.5z" />
            </svg>
            <div>
              <p class="font-bold text-black text-sm uppercase tracking-wide mb-1">Location</p>
              <a
                href="https://www.google.com/maps/search/?api=1&query=423+Farabee+Dr+S+Lafayette+IN+47905"
                target="_blank"
                rel="noopener noreferrer"
                class="text-gray-body hover:text-gold transition-colors"
              >
                423 Farabee Dr S<br />Lafayette, IN 47905
              </a>
            </div>
          </div>

          <!-- Social -->
          <div>
            <p class="font-bold text-black text-sm uppercase tracking-wide mb-3">Follow Us</p>
            <div class="flex gap-4">
              <a href="https://www.facebook.com/Real-World-PDR-385803952162523/" target="_blank" rel="noopener noreferrer" class="text-gray-body hover:text-gold transition-colors" aria-label="Facebook">
                <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" /></svg>
              </a>
              <a href="https://www.instagram.com/real_world_pdr/" target="_blank" rel="noopener noreferrer" class="text-gray-body hover:text-gold transition-colors" aria-label="Instagram">
                <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z" /></svg>
              </a>
              <a href="https://www.youtube.com/channel/UC-_8JJqmDF7-LTDLR_2WRhQ" target="_blank" rel="noopener noreferrer" class="text-gray-body hover:text-gold transition-colors" aria-label="YouTube">
                <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z" /></svg>
              </a>
            </div>
          </div>
        </div>

        <!-- Quick Links -->
        <div class="mt-8">
          <h3 class="font-bold text-black mb-3">Looking for something else?</h3>
          <ul class="space-y-2">
            <li>
              <a href="/real-world-pdr-courses" class="text-gold hover:underline">Browse our online courses</a>
            </li>
            <li>
              <a href="/in-person-training" class="text-gold hover:underline">In-person training info</a>
            </li>
            <li>
              <a href="/pdr-101" class="text-gold hover:underline">Get started with PDR 101</a>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>
