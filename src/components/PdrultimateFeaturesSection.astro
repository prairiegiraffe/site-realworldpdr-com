---
export interface Props {
  className?: string;
}

const { className = "" } = Astro.props;
---

<section id="features" class={`py-16 px-4 bg-gray-50 ${className}`}>
  <div class="max-w-4xl mx-auto text-center">
    <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-6">
      Be The First To Know...
    </h2>
    
    <p class="text-lg text-gray-700 mb-8 max-w-3xl mx-auto leading-relaxed">
      With our Real World PDR Ultimate course you'll always receive our latest lessons, tips, and techniques. Maintain your reputation as a top of the line PDR Technician and always have the knowledge needed to repair even the most challenging dents.
    </p>
    
    <a 
      href="https://realworldpdr.thinkific.com/cart/add_product/446304?price_id=467664"
      class="inline-block bg-blue-600 hover:bg-blue-700 text-white font-semibold py-3 px-8 rounded-lg transition-colors duration-200 uppercase tracking-wide"
    >
      Buy The Course
    </a>
  </div>
</section>
